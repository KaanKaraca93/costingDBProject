# Heroku Postgres otomatik olarak DATABASE_URL sağlar; local'de kendi Postgres bağlantı stringinizi girin.
DATABASE_URL=postgres://kullanici:sifre@localhost:5432/ipekyol_costing

# Yerelde Heroku Postgres SSL zorunlu değilse false birakabilirsiniz. Heroku'da PG_SSL=true olmalı.
PG_SSL=false

PORT=3000

# NOT: PLM/ION servis hesabı bilgileri şimdilik src/config/plm.config.js içinde
# hardcoded tutuluyor (bkz. proje notları). Entegrasyon stabilleştikten sonra
# buraya PLM_TENANT_ID, PLM_CLIENT_ID, PLM_CLIENT_SECRET vb. eklenerek env'e taşınacak.
